package templ

templ Library(query string, groups []PoemGroup) {
	<div class="space-y-6" style="height: calc(100svh - 4rem); padding-top: clamp(7rem, 16vh, 9rem);">
		<h1 class="text-2xl font-serif leading-none text-neutral-200">
			Library
		</h1>
		<div class="max-w-none min-h-0 flex-1">
			@LibraryContent(query, groups)
		</div>
	</div>
}
